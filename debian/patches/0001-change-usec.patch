diff --git a/debian/tests/validate-usec b/debian/tests/validate-usec
new file mode 100644
index 0000000..4f62b9d
--- /dev/null
+++ b/debian/tests/validate-usec
@@ -0,0 +1,26 @@
+#!/bin/sh
+
+set -eu
+
+tmpdir=$(mktemp -d)
+
+cd "${tmpdir}"
+
+cp /usr/share/selinux/usec/*.pp.bz2 .
+
+bzip2 -d *.pp.bz2
+
+mv base.pp base
+
+semodule_link -o test.lnk base *.pp
+semodule_expand test.lnk policy.bin
+
+mv base base.pp
+
+mkdir -p policy_root/var/lib/selinux/usec
+
+# ignore 'FAIL stderr: libsemanage.add_user: user sddm not in password file'
+/usr/sbin/semodule --noreload --store usec --path policy_root --verbose --install *.pp 2>&1
+
+/sbin/setfiles -c policy_root/etc/selinux/usec/policy/policy.* policy_root/etc/selinux/usec/contexts/files/file_contexts
+
